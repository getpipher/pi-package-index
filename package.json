{
  "name": "pi-package-index",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unofficial community index of Pi coding-agent packages — ranked by downloads + stars + maintenance, with a public API.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/copy-data.mjs",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "pipeline": "tsx pipeline/run.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  },
  "dependencies": {
    "flexsearch": "^0.8.212",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}